{
  "name": "@svc/server",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "npm run test:integration && npm run test:crypto",
    "test:integration": "tsx --test tests/api.integration.test.ts",
    "test:crypto": "tsx --test tests/crypto.invariants.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.1.0",
    "@fastify/static": "^9.1.3",
    "better-sqlite3": "^12.9.0",
    "csv-parse": "^6.2.1",
    "fastify": "^5.2.1",
    "pdfkit": "^0.16.0",
    "playwright": "^1.53.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/pdfkit": "^0.17.6",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3"
  }
}
