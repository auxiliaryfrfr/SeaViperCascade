{
  "name": "@svc/desktop",
  "version": "1.0.1",
  "private": true,
  "description": "SeaViperCascade desktop shell",
  "author": "SeaViperCascade",
  "main": "main.cjs",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@svc/server": "file:../server",
    "@svc/web": "file:../web",
    "wait-on": "^9.0.5"
  },
  "devDependencies": {
    "electron": "39.8.5",
    "electron-builder": "^26.0.12",
    "node-gyp": "^12.3.0",
    "prebuild-install": "^7.1.3"
  },
  "build": {
    "appId": "com.seavipercascade.desktop",
    "productName": "SeaViperCascade",
    "afterPack": "scripts/install-electron-native.cjs",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.cjs"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "extraMetadata": {
      "main": "main.cjs"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false,
      "artifactName": "SeaViperCascade-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
