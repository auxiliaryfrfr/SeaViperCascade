{
  "name": "@svc/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "SeaViperCascade desktop shell",
  "author": "SeaViperCascade",
  "main": "main.cjs",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "wait-on": "^8.0.1"
  },
  "devDependencies": {
    "electron": "35.4.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.seavipercascade.desktop",
    "productName": "SeaViperCascade",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.cjs"
    ],
    "extraMetadata": {
      "main": "main.cjs"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false,
      "artifactName": "SeaViperCascade-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}